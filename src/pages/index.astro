---
import Layout from '../layouts/Layout.astro';
---

<Layout title="vesl — Verified RAG on Nockchain">
  <main>
    <nav>
      <div class="nav-inner">
        <a href="/" class="logo">vesl</a>
        <div class="nav-links">
          <a href="https://docs.zkvesl.org">docs</a>
          <a href="https://github.com/zkVesl/vesl">github</a>
        </div>
      </div>
    </nav>

    <section class="hero">
      <div class="hero-inner">
        <h1>vesl</h1>
        <p class="tagline">Verified RAG on Nockchain.</p>
        <p class="sub">
          You shouldn't need to trust an API to know your retrieval was honest.
          vesl makes RAG verifiable — every query, every chunk, every proof on-chain.
        </p>
        <div class="cta">
          <a href="https://docs.zkvesl.org" class="btn primary">Read the docs</a>
          <a href="https://github.com/zkVesl/vesl" class="btn secondary">View source</a>
        </div>
      </div>
    </section>

    <section class="features">
      <div class="features-inner">
        <div class="feature">
          <h3>Verified retrieval</h3>
          <p>Every chunk lookup produces a cryptographic proof. No blind trust in your RAG pipeline.</p>
        </div>
        <div class="feature">
          <h3>Nockchain native</h3>
          <p>Built on Nock — deterministic computation you can verify without re-executing.</p>
        </div>
        <div class="feature">
          <h3>Ship your own hull</h3>
          <p>The Rust harness that runs your Hoon kernel. Configure, compile, deploy.</p>
        </div>
      </div>
    </section>

    <footer>
      <p class="sigil">~</p>
    </footer>
  </main>
</Layout>

<style>
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-family: var(--font-mono);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--accent);
    letter-spacing: -0.02em;
  }

  .logo:hover {
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--muted);
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--fg);
    text-decoration: none;
  }

  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }

  .hero-inner {
    max-width: 680px;
    text-align: center;
  }

  h1 {
    font-family: var(--font-mono);
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: var(--accent);
    margin-bottom: 1rem;
  }

  .tagline {
    font-size: 1.4rem;
    color: var(--fg);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  .sub {
    color: var(--muted);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 540px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.75rem 2rem;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn:hover {
    text-decoration: none;
  }

  .btn.primary {
    background: var(--accent);
    color: var(--bg);
  }

  .btn.primary:hover {
    background: #00dd8a;
    transform: translateY(-1px);
  }

  .btn.secondary {
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: var(--fg);
  }

  .btn.secondary:hover {
    border-color: var(--accent);
    color: var(--accent);
    transform: translateY(-1px);
  }

  .features {
    padding: 6rem 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .features-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 3rem;
  }

  .feature h3 {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .feature p {
    color: var(--muted);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  footer {
    padding: 4rem 2rem;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .sigil {
    font-family: var(--font-mono);
    font-size: 2rem;
    color: var(--muted);
  }
</style>
