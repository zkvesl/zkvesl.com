</style>

<script>
  // --- Scroll reveal (fade-up) ---
  const reveal = (el: Element) => el.classList.add('revealed');

  const revealTargets = document.querySelectorAll<HTMLElement>('[data-reveal]');

  // --- Typewriter on code blocks ---
  const typeTargets = document.querySelectorAll<HTMLElement>('[data-typewriter]');
  const originalText = new WeakMap<HTMLElement, string>();

  // Capture original text + reserve min-height so layout doesn't jump
  typeTargets.forEach((el) => {
    originalText.set(el, el.textContent ?? '');
    const h = el.offsetHeight;
    if (h > 0) el.style.minHeight = h + 'px';
  });

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function typewriter(el: HTMLElement) {
    if (el.dataset.typed === 'true') return;
    el.dataset.typed = 'true';

    const full = originalText.get(el) ?? '';
    if (prefersReducedMotion || full.length === 0) {
      el.classList.add('typed');
      return;
    }

    el.textContent = '';
    el.classList.add('typing');

    const len = full.length;
    // Finish in ~70-90 frames → ~1.2s at 60fps
    const charsPerTick = Math.max(2, Math.ceil(len / 80));
    let i = 0;

    const tick = () => {
      i = Math.min(i + charsPerTick, len);
      el.textContent = full.slice(0, i);
      if (i < len) {
        requestAnimationFrame(tick);
      } else {
        el.classList.remove('typing');
        el.classList.add('typed');
      }
    };
    requestAnimationFrame(tick);
  }

  // --- IntersectionObserver wiring ---
  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          if (el.hasAttribute('data-reveal')) reveal(el);
          if (el.hasAttribute('data-typewriter')) typewriter(el);
          io.unobserve(el);
        }
      }
    }, { threshold: 0.15, rootMargin: '0px 0px -60px 0px' });

    const engage = (el: HTMLElement) => {
      const rect = el.getBoundingClientRect();
      if (rect.top < window.innerHeight && rect.bottom > 0) {
        if (el.hasAttribute('data-reveal')) reveal(el);
        if (el.hasAttribute('data-typewriter')) typewriter(el);
      } else {
        io.observe(el);
      }
    };

    revealTargets.forEach(engage);
    typeTargets.forEach(engage);
  } else {
    revealTargets.forEach(reveal);
    typeTargets.forEach((el) => el.classList.add('typed'));
  }

  // --- Catalog scrubber: dot tracking + hint dismiss ---
  const grid = document.querySelector<HTMLElement>('.catalog-grid');
  const dots = document.querySelectorAll<HTMLElement>('.scrub-dot');
  const hint = document.querySelector<HTMLElement>('.scrub-hint');

  if (grid && dots.length) {
    const groups = grid.querySelectorAll<HTMLElement>('.catalog-group');

    const updateDots = () => {
      if (groups.length === 0) return;
      const gridRect = grid.getBoundingClientRect();
      const center = gridRect.left + gridRect.width / 2;
      let closest = 0;
      let minDist = Infinity;
      groups.forEach((g, i) => {
        const r = g.getBoundingClientRect();
        const gc = r.left + r.width / 2;
        const dist = Math.abs(gc - center);
        if (dist < minDist) { minDist = dist; closest = i; }
      });
      dots.forEach((d, i) => d.classList.toggle('active', i === closest));
    };

    let hintDismissed = false;
    const onScroll = () => {
      updateDots();
      if (!hintDismissed && grid.scrollLeft > 20 && hint) {
        hint.classList.add('dismissed');
        hintDismissed = true;
      }
    };

    grid.addEventListener('scroll', onScroll, { passive: true });
    updateDots();

    // Auto-hide hint after 6s even if user doesn't scroll
    if (hint) {
      setTimeout(() => { if (!hintDismissed) hint.classList.add('dismissed'); }, 6000);
    }
  }
</script>
