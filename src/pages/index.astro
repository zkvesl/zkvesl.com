---
import Layout from '../layouts/Layout.astro';
import DataField from '../components/DataField.astro';
---

<Layout title="vesl">
  <DataField />
  <main>
    <nav>
      <div class="nav-inner">
        <a href="/" class="logo">
          <img src="/logo.svg" alt="vesl" class="logo-mark" />
        </a>
        <div class="nav-links">
          <a href="https://docs.zkvesl.org">docs</a>
          <a href="https://github.com/zkVesl/vesl">github</a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <h1><img src="/vesl_horizontal_alpha.svg" alt="vesl" class="hero-logo" /></h1>
        <p class="tagline">
          The verification and settlement layer for any NockApp
        </p>
        <p class="sub">
          A growing catalog of composable grafts, verification gates, and Rust crates — injected into your kernel, wired from Rust.
        </p>
        <div class="cta">
          <a href="https://docs.zkvesl.org" class="btn primary">Get started</a>
          <a href="https://github.com/zkVesl/vesl" class="btn secondary">View source</a>
        </div>
      </div>
    </section>

    <!-- CARD 1 — alien language, human interface -->
    <section class="card" id="card-1">
      <div class="card-inner" data-reveal>
        <span class="card-number">01</span>
        <h2>alien language, human interface</h2>
        <div class="card-rule"></div>
        <p>
          ::  Hoon compiles to Nock. Dense, precise, and unforgiving by design. Most developers never need to learn it. Vesl maintains the Hoon side of your app — grafts, gates, verification logic — so you work in Rust and TOML, not Hoon.
        </p>
      </div>
      <pre class="card-code" aria-hidden="true" data-typewriter>++  verify-chunk
  |=  $:  chunk=@
          proof=(list [hash=@ side=?])
          expected-root=@
      ==
  ^-  ?
  ?:  (gth (lent proof) 64)  %.n
  =/  cur=@  (hash-leaf chunk)
  |-
  ?~  proof
    =(cur expected-root)
  =/  nex=@
    ?:  side.i.proof
      (hash-pair hash.i.proof cur)
    (hash-pair cur hash.i.proof)
  $(cur nex, proof t.proof)</pre>
    </section>

    <!-- CARD 2 — a library, not a language -->
    <section class="card" id="card-2">
      <div class="card-inner" data-reveal>
        <span class="card-number">02</span>
        <h2>a library, not a language</h2>
        <div class="card-rule"></div>
        <p>
          ::  Vesl is not a compiler from Rust to Hoon. It's a catalog of Hoon grafts, pre-written verification gates, and Rust crates that every Nockchain verification app ends up needing. Vesl maintains them. You inject them into your kernel, wire them from Rust, and keep writing your app. No language abstraction. No hidden runtime.
        </p>
      </div>
      <pre class="card-code" aria-hidden="true" data-typewriter># nockapp.toml

[package]
name     = "my-app"
version  = "0.1.0"
template = "basic"

[settle-graft]
gate-chain = [
  "sig-verify-ed25519",
  "manifest-verify",
]

[mint-graft]
hull = 1</pre>
    </section>

    <!-- CARD 3 — the catalog (full-width) -->
    <section class="card card-full" id="card-3">
      <div class="card-inner-wide">
        <div data-reveal>
          <span class="card-number">03</span>
          <h2>the catalog</h2>
          <div class="card-rule"></div>
          <p class="catalog-lede">
            ::  Four categories. Pick what you need. Compose from Rust.
          </p>
        </div>

        <div class="catalog-grid" role="region" aria-label="primitive catalog, scroll horizontally">
          <div class="catalog-group">
            <h3 class="catalog-group-title">commitment grafts</h3>
            <p class="catalog-group-desc">::  The plumbing of proof. Commit data, verify roots, settle notes, prove computations. The four primitives every verification app routes through.</p>
            <ul class="catalog-list">
              <li><code>mint</code> <span class="catalog-desc">::  append-only merkle commitment</span></li>
              <li><code>settle</code> <span class="catalog-desc">::  hard settlement, replay protection</span></li>
              <li><code>guard</code> <span class="catalog-desc">::  soft verification, returns loobean</span></li>
              <li><code>forge</code> <span class="catalog-desc">::  stark proofs, epoch-versioned</span></li>
            </ul>
          </div>

          <div class="catalog-group">
            <h3 class="catalog-group-title">verification gates</h3>
            <p class="catalog-group-desc">::  Pre-written verification predicates. Pick one in the manifest, or chain several for multi-step verification. Never hand-write a gate.</p>
            <ul class="catalog-list">
              <li><code>sig-verify-ed25519</code> <span class="catalog-desc">::  signed attestations</span></li>
              <li><code>sig-verify-schnorr</code> <span class="catalog-desc">::  nockchain-native signatures</span></li>
              <li><code>manifest-verify</code> <span class="catalog-desc">::  structured-document commitment</span></li>
              <li><code>set-membership</code> <span class="catalog-desc">::  allowlist / blocklist</span></li>
              <li><code>range-proof</code> <span class="catalog-desc">::  age gates, balance checks</span></li>
            </ul>
          </div>

          <div class="catalog-group">
            <h3 class="catalog-group-title">state grafts</h3>
            <p class="catalog-group-desc">::  Opinionated state shapes. Registries, queues, counters, permissions — domain-keyed scaffolding that slots into your kernel à la carte. State you don't write.</p>
            <ul class="catalog-list">
              <li><code>registry</code> <span class="catalog-desc">::  user directories, config stores</span></li>
              <li><code>queue</code> <span class="catalog-desc">::  job queues, request backlogs</span></li>
              <li><code>counter</code> <span class="catalog-desc">::  sequence numbers, nonces, metering</span></li>
              <li><code>rbac</code> <span class="catalog-desc">::  permission enforcement</span></li>
              <li><code>kv</code> <span class="catalog-desc">::  simple key-value store</span></li>
            </ul>
          </div>

          <div class="catalog-group">
            <h3 class="catalog-group-title">behavior grafts</h3>
            <p class="catalog-group-desc">::  TOML-configured runtime rules. Input validation, lifecycle state machines, secondary indexes, audit logs, deterministic time. The wiring around your state.</p>
            <ul class="catalog-list">
              <li><code>validate</code> <span class="catalog-desc">::  field rules before poke runs</span></li>
              <li><code>fsm</code> <span class="catalog-desc">::  enforce state transitions</span></li>
              <li><code>index</code> <span class="catalog-desc">::  secondary indexes on map state</span></li>
              <li><code>log</code> <span class="catalog-desc">::  monotonic audit trail</span></li>
              <li><code>clock</code> <span class="catalog-desc">::  deterministic time primitive</span></li>
              <li><code>batch</code> <span class="catalog-desc">::  buffer intents, flush on trigger</span></li>
            </ul>
          </div>
        </div>

        <div class="scrub-dots" aria-hidden="true">
          <span class="scrub-dot" data-scrub-dot="0"></span>
          <span class="scrub-dot" data-scrub-dot="1"></span>
          <span class="scrub-dot" data-scrub-dot="2"></span>
          <span class="scrub-dot" data-scrub-dot="3"></span>
        </div>
        <p class="scrub-hint" aria-hidden="true">::  swipe →</p>

      </div>
    </section>

    <!-- CARD 4 — pre-compiled hulls -->
    <section class="card" id="card-4">
      <div class="card-inner" data-reveal>
        <span class="card-number">04</span>
        <h2>pre-compiled hulls</h2>
        <div class="card-rule"></div>
        <p>
          ::  A hull is a complete NockApp kernel wired for a specific domain. Grafts composed. Gates chosen. State shapes decided. Fork it, bring your domain data, and ship.
        </p>
        <p class="card-coda">
          <code>hull-llm</code> is the first reference hull — attested LLM generation against a committed document set. Nothing to wire by hand.
        </p>
      </div>
      <pre class="card-code" aria-hidden="true" data-typewriter>::  hull-llm

──  ingest
docs → chunk → tip5 merkle → %register

──  query
q → retrieve → proofs → llm → manifest
                                │
                                ▼
                         %settle
                         verify-chunk
                         build-prompt
                         pending → settled
                                │
                                ▼
                         on-chain note</pre>
    </section>

    <!-- STATUS FLAG -->
    <section class="status-flag" data-reveal>
      <p>Vesl is in active development. Ships soon.</p>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="footer-inner">
        <div class="footer-links">
          <a href="https://docs.zkvesl.org">docs</a>
          <a href="https://github.com/zkVesl/vesl">github</a>
        </div>
      </div>
    </footer>
  </main>

  <div class="nockchain-bar">
    :: BUILT ON NOCKCHAIN ::
  </div>
</Layout>

<style>
  /* NAV */
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    background: rgba(246, 241, 231, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--rule);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo { display: flex; align-items: center; }
  .logo:hover { text-decoration: none; }
  .logo-mark { height: 28px; width: auto; }

  .nav-links {
    display: flex;
    gap: 2rem;
    font-family: var(--font-mono);
  }

  .nav-links a {
    color: var(--muted);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    position: relative;
  }

  .hero-inner {
    max-width: 720px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  h1 {
    margin-bottom: 1.4rem;
    position: relative;
    display: inline-block;
  }

  .hero-logo {
    height: clamp(2.2rem, 6vw, 3.5rem);
    width: auto;
    clip-path: inset(0 100% 0 0);
    animation: logo-reveal 1.4s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards;
  }

  /* Plotter-pen line that tracks the clip edge during reveal */
  h1::after {
    content: '';
    position: absolute;
    top: -4%;
    bottom: -4%;
    left: 0;
    width: 1px;
    background: var(--ink);
    opacity: 0;
    transform-origin: left center;
    animation: plotter-pen 1.4s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards;
    pointer-events: none;
  }

  @keyframes logo-reveal {
    0%   { clip-path: inset(0 100% 0 0); }
    100% { clip-path: inset(0 0 0 0); }
  }

  @keyframes plotter-pen {
    0%   { left: 0;    opacity: 0; }
    8%   { opacity: 0.9; }
    85%  { opacity: 0.9; }
    100% { left: 100%; opacity: 0; }
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: clamp(1.05rem, 1.8vw, 1.2rem);
    line-height: 1.7;
    color: var(--ink);
    margin-bottom: 0.4rem;
    font-weight: 500;
    letter-spacing: -0.01em;
    opacity: 0;
    animation: fade-up 0.8s ease-out 0.9s forwards;
  }

  .sub-lede {
    font-family: var(--font-mono);
    font-size: 0.92rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
    letter-spacing: 0.01em;
    opacity: 0;
    animation: fade-up 0.8s ease-out 1.1s forwards;
  }

  .sub {
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.75;
    margin-bottom: 2.5rem;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
    font-family: var(--font-mono);
    opacity: 0;
    animation: fade-up 0.8s ease-out 1.3s forwards;
  }

  .cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    opacity: 0;
    animation: fade-up 0.8s ease-out 1.5s forwards;
  }

  @keyframes fade-up {
    0%   { opacity: 0; transform: translateY(4px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-logo,
    h1::after,
    .tagline,
    .sub-lede,
    .sub,
    .cta {
      animation: none !important;
      opacity: 1 !important;
      clip-path: none !important;
    }
  }

  /* SCROLL REVEAL */
  [data-reveal] {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.9s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }

  [data-reveal][data-reveal-delay="1"].revealed { transition-delay: 0.12s; }
  [data-reveal][data-reveal-delay="2"].revealed { transition-delay: 0.24s; }
  [data-reveal][data-reveal-delay="3"].revealed { transition-delay: 0.36s; }
  [data-reveal][data-reveal-delay="4"].revealed { transition-delay: 0.48s; }
  [data-reveal][data-reveal-delay="5"].revealed { transition-delay: 0.60s; }

  /* TYPEWRITER — code blocks and spec header */
  [data-typewriter] {
    opacity: 0;
    transition: opacity 0.35s ease-out;
  }

  [data-typewriter].typing,
  [data-typewriter].typed {
    opacity: 1;
  }

  /* Subtle blinking caret while typing */
  [data-typewriter].typing::after {
    content: '▍';
    display: inline-block;
    color: var(--ink);
    animation: caret-blink 0.9s steps(2, start) infinite;
    margin-left: 1px;
    opacity: 0.75;
  }

  @keyframes caret-blink {
    to { visibility: hidden; }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal],
    [data-typewriter] {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    [data-typewriter].typing::after { display: none; }
  }

  .btn {
    padding: 0.65rem 1.8rem;
    border-radius: 2px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: all 0.15s;
    display: inline-block;
    text-decoration: none;
  }

  .btn:hover { text-decoration: none; }

  .btn.primary {
    background: var(--ink);
    color: var(--bg);
  }

  .btn.primary:hover {
    background: #2a2a22;
    transform: translateY(-1px);
  }

  .btn.secondary {
    border: 1px solid var(--ink);
    color: var(--ink);
    background: transparent;
  }

  .btn.secondary:hover {
    background: var(--ink);
    color: var(--bg);
    transform: translateY(-1px);
  }

  /* SPEC HEADER BLOCK */
  .spec-header {
    max-width: 780px;
    margin: 0 auto;
    padding: 3rem 2rem 1.5rem;
    position: relative;
    z-index: 1;
  }

  .spec-block {
    font-family: var(--font-mono);
    font-size: 0.88rem;
    line-height: 1.75;
    color: var(--ink);
    white-space: pre;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 1.4rem 0;
    opacity: 0.88;
  }

  /* NOCKCHAIN BAR */
  .nockchain-bar {
    position: fixed;
    bottom: 0;
    width: 100%;
    z-index: 100;
    background: rgba(246, 241, 231, 0.95);
    backdrop-filter: blur(12px);
    border-top: 1px solid var(--rule);
    padding: 0.75rem 2rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--ink);
    font-weight: 500;
    letter-spacing: 0.05em;
    opacity: 0.85;
  }

  /* CONTENT LAYER — sits above canvas */
  main {
    position: relative;
    z-index: 1;
  }

  /* CARDS */
  .card {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4rem;
    padding: 4rem 8%;
    position: relative;
    border-top: 1px solid var(--rule);
  }

  .card-code {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.85;
    color: var(--ink);
    white-space: pre;
    border: 1px solid var(--rule);
    background: var(--paper-shade);
    padding: 1.5rem 2rem;
    border-radius: 2px;
    flex-shrink: 0;
    overflow-x: auto;
    opacity: 0.92;
  }

  .card-inner {
    max-width: 520px;
    position: relative;
    z-index: 1;
  }

  .card-number {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 1.3rem;
  }

  .card h2 {
    font-family: var(--font-mono);
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin-bottom: 1rem;
    line-height: 1.25;
  }

  .card-rule {
    width: 40px;
    height: 1px;
    background: var(--ink);
    margin-bottom: 1.4rem;
    opacity: 0.5;
  }

  .card p {
    color: var(--ink);
    font-size: 1.02rem;
    line-height: 1.8;
    opacity: 0.82;
    font-family: var(--font-mono);
  }

  .card .card-coda {
    margin-top: 1rem;
    font-size: 0.92rem;
    opacity: 0.65;
  }

  /* Even cards reverse: code left, text right */
  #card-2, #card-4 { flex-direction: row-reverse; }

  /* CARD 3 — full-width catalog */
  .card-full {
    flex-direction: column;
    align-items: stretch;
    padding: 4rem 8%;
  }

  .card-inner-wide {
    max-width: 1000px;
    width: 100%;
    margin: 0 auto;
  }

  .catalog-lede {
    margin-bottom: 2rem !important;
  }

  .catalog-grid {
    display: flex;
    flex-direction: row;
    gap: 1.2rem;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    margin: 1.2rem 0 0.6rem;
    padding: 0.25rem 0 0.9rem;
  }

  .catalog-grid::-webkit-scrollbar { display: none; }

  .catalog-group {
    flex: 0 0 min(86%, 420px);
    scroll-snap-align: start;
    border-top: 1px solid var(--rule);
    border-left: 1px solid var(--rule);
    padding: 1.1rem 1.2rem 1.3rem;
    background: var(--faint);
  }

  .scrub-dots {
    display: flex;
    gap: 0.55rem;
    justify-content: center;
    align-items: center;
    margin: 0.4rem 0 0.2rem;
  }

  .scrub-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: transparent;
    border: 1px solid var(--muted);
    transition: background 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    display: inline-block;
  }

  .scrub-dot.active {
    background: var(--ink);
    border-color: var(--ink);
    transform: scale(1.15);
  }

  .scrub-hint {
    font-family: var(--font-mono);
    font-size: 0.78rem !important;
    color: var(--muted) !important;
    text-align: center;
    opacity: 0.7 !important;
    margin-bottom: 1.4rem !important;
    letter-spacing: 0.04em;
    animation: hint-pulse 3.4s ease-in-out infinite;
  }

  @keyframes hint-pulse {
    0%, 100% { opacity: 0.45 !important; }
    50%      { opacity: 0.85 !important; }
  }

  .scrub-hint.dismissed {
    opacity: 0 !important;
    animation: none;
    pointer-events: none;
    transition: opacity 0.5s ease-out;
  }

  .catalog-group-title {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
    margin-bottom: 0.6rem;
    letter-spacing: -0.005em;
  }

  .group-note {
    color: var(--muted);
    font-weight: 400;
    margin-left: 0.5rem;
  }

  .catalog-group-desc {
    font-family: var(--font-mono);
    font-size: 0.78rem !important;
    color: var(--muted) !important;
    line-height: 1.7 !important;
    margin-bottom: 0.9rem !important;
    opacity: 0.92 !important;
  }

  .catalog-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.86rem;
    line-height: 2;
  }

  .catalog-list li {
    color: var(--ink);
    opacity: 0.9;
  }

  .catalog-list code {
    color: var(--ink);
    font-weight: 500;
  }

  .catalog-desc {
    color: var(--muted);
    margin-left: 0.4rem;
  }

  .catalog-coda {
    margin-top: 1.5rem !important;
    font-size: 0.94rem !important;
    opacity: 0.75 !important;
  }

  /* CHIPS — primitive status markers */
  .chip {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    padding: 0.1rem 0.45rem;
    border: 1px solid var(--ink);
    border-radius: 1px;
    margin-right: 0.55rem;
    text-transform: lowercase;
    line-height: 1.4;
    vertical-align: 1px;
  }

  .chip-ship { background: var(--ink); color: var(--bg); }
  .chip-next { background: transparent; color: var(--ink); }
  .chip-plan {
    background: transparent;
    color: var(--muted);
    border-color: var(--muted);
    border-style: dashed;
  }

  /* STATUS FLAG */
  .status-flag {
    padding: 3.5rem 2rem 3rem;
    text-align: center;
    border-top: 1px solid var(--rule);
    position: relative;
    z-index: 1;
  }

  .status-flag p {
    font-family: var(--font-mono);
    font-size: 1rem;
    color: var(--ink);
    opacity: 0.75;
    letter-spacing: 0.01em;
    line-height: 1.6;
  }

  /* FOOTER */
  footer {
    padding: 3rem 2rem 4.5rem;
    border-top: 1px solid var(--rule);
    position: relative;
    z-index: 1;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
