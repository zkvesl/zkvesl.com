---
import Layout from '../layouts/Layout.astro';
import DataField from '../components/DataField.astro';
---

<Layout title="vesl">
  <DataField />
  <main>
    <nav>
      <div class="nav-inner">
        <a href="/" class="logo">
          <img src="/logo.svg" alt="vesl" class="logo-mark" />
        </a>
        <div class="nav-links">
          <a href="https://docs.zkvesl.org">docs</a>
          <a href="https://github.com/zkVesl/vesl">github</a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section class="hero">
      <div class="hero-inner">
        <h1>vesl</h1>
        <p class="tagline">
          Verifiable Execution and Settlement Layer
        </p>
        <p class="sub">
          Build on infrastructure where every computation is provable and every state transition is verified. No trust required.
        </p>
        <div class="cta">
          <a href="https://docs.zkvesl.org" class="btn primary">Get started</a>
          <a href="https://github.com/zkVesl/vesl" class="btn secondary">View source</a>
        </div>
      </div>
      <div class="scroll-hint" aria-hidden="true">&#8595;</div>
    </section>

    <!-- CARD 1 -->
    <section class="card" id="card-1">
      <div class="card-inner">
        <span class="card-number">01</span>
        <h2>verifiable by default</h2>
        <div class="card-rule"></div>
        <p>
          Every operation produces a cryptographic proof. Not as an add-on. Not as a premium feature. As the foundation. If it ran, you can verify it. If you can't verify it, it didn't run.
        </p>
      </div>
    </section>

    <!-- CARD 2 -->
    <section class="card" id="card-2">
      <div class="card-inner">
        <span class="card-number">02</span>
        <h2>nockchain native</h2>
        <div class="card-rule"></div>
        <p>
          Nock is a minimal, deterministic virtual machine. Same input, same output, every time. Your application logic compiles down to something a machine can prove and anyone can verify. No opaque runtimes. No trust assumptions.
        </p>
      </div>
    </section>

    <!-- CARD 3 -->
    <section class="card" id="card-3">
      <div class="card-inner">
        <span class="card-number">03</span>
        <h2>build in rust, settle on-chain. that's it.</h2>
        <div class="card-rule"></div>
        <p>
          You write Rust — configure your settlement mode, point at a network, and ship. Don't know Hoon? You're not alone. The kernels are already compiled, so you won't need to.
        </p>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="footer-inner">
        <div class="footer-links">
          <a href="https://docs.zkvesl.org">docs</a>
          <a href="https://github.com/zkVesl/vesl">github</a>
        </div>
        <p class="sigil">~</p>
      </div>
    </footer>
  </main>
</Layout>

<style>
  /* NAV */
  nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 100;
    background: rgba(10, 10, 10, 0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--rule);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .logo:hover { text-decoration: none; }

  .logo-mark {
    height: 28px;
    width: auto;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    font-family: var(--font-mono);
  }

  .nav-links a {
    color: var(--muted);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--fg);
    text-decoration: none;
  }

  /* HERO */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    position: relative;
  }

  .hero-inner {
    max-width: 720px;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  h1 {
    font-family: var(--font-mono);
    font-size: clamp(2.8rem, 7vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--fg);
    margin-bottom: 1.2rem;
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    color: var(--fg);
    margin-bottom: 1rem;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  .sub {
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 2.5rem;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }

  .cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 0.65rem 1.8rem;
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: all 0.2s;
    display: inline-block;
  }

  .btn:hover { text-decoration: none; }

  .btn.primary {
    background: var(--accent);
    color: var(--bg);
  }

  .btn.primary:hover {
    background: #00dd8a;
    transform: translateY(-1px);
  }

  .btn.secondary {
    border: 1px solid var(--rule);
    color: var(--muted);
  }

  .btn.secondary:hover {
    border-color: rgba(214, 214, 214, 0.2);
    color: var(--fg);
    transform: translateY(-1px);
  }

  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    font-family: var(--font-mono);
    font-size: 1.2rem;
    color: var(--muted);
    animation: pulse 2.5s ease-in-out infinite;
    z-index: 1;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.2; transform: translateY(0); }
    50% { opacity: 0.6; transform: translateY(5px); }
  }

  /* CONTENT LAYER — sits above canvas */
  main {
    position: relative;
    z-index: 1;
  }

  /* CARDS */
  .card {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem;
    position: relative;
    border-top: 1px solid var(--rule);
  }

  .card-inner {
    max-width: 560px;
    position: relative;
    z-index: 1;
    /* subtle dark backing so text reads clean over the data field */
    background: radial-gradient(ellipse at center, rgba(10, 10, 10, 0.85) 0%, transparent 70%);
    padding: 3rem;
  }

  .card-number {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--accent);
    letter-spacing: 0.15em;
    display: block;
    margin-bottom: 1.5rem;
    opacity: 0.7;
  }

  .card h2 {
    font-family: var(--font-mono);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--fg);
    margin-bottom: 1.2rem;
    line-height: 1.25;
  }

  .card-rule {
    width: 40px;
    height: 1px;
    background: var(--accent);
    margin-bottom: 1.5rem;
    opacity: 0.4;
  }

  .card p {
    color: var(--muted);
    font-size: 1.05rem;
    line-height: 1.8;
  }

  /* Alternate alignment */
  #card-1 { justify-content: flex-start; padding-left: 12%; }
  #card-2 { justify-content: flex-end; padding-right: 12%; }
  #card-3 { justify-content: flex-start; padding-left: 12%; }

  /* FOOTER */
  footer {
    padding: 3rem 2rem;
    border-top: 1px solid var(--rule);
    position: relative;
    z-index: 1;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-links {
    display: flex;
    gap: 2rem;
    font-family: var(--font-mono);
  }

  .footer-links a {
    color: var(--muted);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--fg);
    text-decoration: none;
  }

  .sigil {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    color: var(--muted);
    opacity: 0.5;
  }

  /* MOBILE */
  @media (max-width: 768px) {
    #card-1, #card-2, #card-3 {
      justify-content: center;
      padding-left: 2rem;
      padding-right: 2rem;
    }

    .card-inner {
      padding: 2rem;
    }

    .footer-inner {
      flex-direction: column;
      gap: 1.5rem;
      text-align: center;
    }
  }
</style>
